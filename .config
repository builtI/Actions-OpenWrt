# This is an empty file, please overwrite it after generating the .config file with the source code
# 目标系统与机型 (必须)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt76x8=y
CONFIG_TARGET_ramips_mt76x8_Device_hc5661a=y

# 额外软件包 (USB, SD卡, AdGuardHome)
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-mmc=y          # SD卡驱动
CONFIG_PACKAGE_block-mount=y       # 挂载工具
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_usbutils=y
